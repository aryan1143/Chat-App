# Server Configuration
PORT=3001

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname

# Redis
REDIS_URL=redis://user:password@host:port

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Firebase Admin SDK
GCP_PROJECT_ID=your-project-id
GCP_PRIVATE_KEY_ID=your-key-id
GCP_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
GCP_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
GCP_CLIENT_ID=your-client-id
GCP_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GCP_TOKEN_URI=https://oauth2.googleapis.com/token
GCP_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
GCP_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/...
GCP_UNIVERSE_DOMAIN=googleapis.com

# ImageKit
IMAGEKIT_PUBLIC_KEY=your-imagekit-public-key
IMAGEKIT_PRIVATE_KEY=your-imagekit-private-key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id
